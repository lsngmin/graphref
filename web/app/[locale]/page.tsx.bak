          <p className="text-[15px] text-zinc-500 leading-relaxed">{a}</p>
        </div>
      </div>
    </div>
  );
}

// Hook: animate children of a ref on scroll entry (Y-only, no opacity)
function useScrollReveal(
  ref: React.RefObject<HTMLElement | null>,
  selector = "[data-reveal]",
  stagger = 0.1
) {
  useEffect(() => {
    if (typeof window === "undefined") return;
    const ctx = gsap.context(() => {
      const els = ref.current?.querySelectorAll(selector);
      if (!els || els.length === 0) return;
      gsap.fromTo(
        els,
        { y: 40 },
        {
          y: 0,
          duration: 0.75,
          ease: "power3.out",
          stagger,
          scrollTrigger: {
            trigger: ref.current,
            start: "top 85%",
            toggleActions: "play none none none",
          },
        }
      );
    }, ref);
    return () => ctx.revert();
  }, [ref, selector, stagger]);
}

