            <p className="text-[17px] md:text-[19px] text-zinc-500 leading-relaxed mb-10 max-w-2xl">
              {t("hero.sub")}
            </p>
            {/* Two CTAs side by side like reference */}
            <div className="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 mb-8">
              <a
                href={TELEGRAM_URL}
                target="_blank"
                rel="noopener noreferrer"
                className="inline-flex items-center justify-center gap-2 bg-zinc-900 text-white text-[15px] font-medium px-7 py-4 rounded-xl hover:bg-zinc-700 transition-colors"
              >
                <MessageCircle size={17} />
                {t("hero.cta")}
              </a>
              <a
                href="#pricing"
                className="inline-flex items-center justify-center gap-2 border border-zinc-300 text-zinc-700 text-[15px] font-medium px-7 py-4 rounded-xl hover:border-zinc-400 hover:bg-zinc-50 transition-colors"
              >
                {t("pricing.title")}
              </a>
            </div>
            <div className="flex flex-wrap gap-x-5 gap-y-1.5 text-[13px] text-zinc-400">
              <span className="flex items-center gap-1.5"><CheckCircle size={13} className="text-emerald-500" />{t("hero.trustCredits")}</span>
              <span className="flex items-center gap-1.5"><CheckCircle size={13} className="text-emerald-500" />{t("hero.trustNoCard")}</span>
              <span className="flex items-center gap-1.5"><CheckCircle size={13} className="text-emerald-500" />{t("hero.trustInstant")}</span>
            </div>
          </div>

          {/* Right: Telegram mock chat */}
          <div className="hidden lg:flex flex-shrink-0 justify-end self-start">
            <TelegramMockChat />
          </div>
        </div>
      </section>

      {/* How it works */}
      <section ref={howRef} className="py-32 md:py-40 px-6 bg-zinc-50">
        <div className="max-w-6xl mx-auto">
          <div data-reveal className="mb-[23px] flex justify-center">
            <Image
              src="/logo-mark.svg"
              alt="Graphref"
              width={512}
              height={512}
              className="h-auto w-[56px] md:w-[64px]"
              priority={false}
            />
          </div>
          <h2 data-reveal className="text-[40px] md:text-[56px] font-bold tracking-tight mb-16 leading-[1.1] text-center">
            {t("howItWorks.title")}
          </h2>
          <div className="flex flex-col lg:flex-row gap-16 items-start lg:justify-between">
            <div className="w-full max-w-xl flex flex-col flex-shrink-0">

              {/* Step 1 */}
              <div data-reveal className="flex gap-5">
                <div className="flex flex-col items-center w-9 shrink-0">
                  <div className="w-9 h-9 rounded-full bg-zinc-900 flex items-center justify-center shrink-0">
                    <Search size={15} className="text-white" />
                  </div>
                  <div className="w-px flex-1 bg-zinc-200 mt-2" />
                </div>
                <div className="pb-5 pt-1">
                  <p className="text-[16px] font-semibold text-zinc-900 mb-1.5">{steps[0].title}</p>
                  <p className="text-[14px] text-zinc-500 leading-relaxed">{steps[0].desc}</p>
                </div>
              </div>

              {/* Visual 1: START button */}
              <div data-reveal className="flex gap-5">
                <div className="flex flex-col items-center w-9 shrink-0">
                  <div className="w-px flex-1 bg-zinc-200" />
                </div>
                <div className="py-3 pl-0">
                  <div className="bg-[#4f81e0] text-white text-[13px] font-semibold px-10 py-2 rounded-xl inline-block shadow-sm">
                    START
                  </div>
                </div>
              </div>

              {/* Step 2 */}
              <div data-reveal className="flex gap-5">
                <div className="flex flex-col items-center">
                  <div className="w-px flex-1 bg-zinc-200 mb-2" />
                  <div className="w-9 h-9 rounded-full bg-zinc-900 flex items-center justify-center shrink-0">
                    <Terminal size={15} className="text-white" />
                  </div>
                  <div className="w-px flex-1 bg-zinc-200 mt-2" />
                </div>
                <div className="py-5 pt-6">
                  <p className="text-[16px] font-semibold text-zinc-900 mb-1.5">{steps[1].title}</p>
                  <p className="text-[14px] text-zinc-500 leading-relaxed">{steps[1].desc}</p>
                </div>
              </div>

              {/* Visual 2: chat input bar */}
              <div data-reveal className="flex gap-5">
                <div className="flex flex-col items-center w-9 shrink-0">
                  <div className="w-px flex-1 bg-zinc-200" />
                </div>
                <div className="py-3">
                  <div className="flex items-center gap-2 bg-white border border-zinc-200 rounded-full px-3 py-2 shadow-sm w-72">
                    <span className="flex-1 text-[13px] text-zinc-500 font-mono">
                      /run keyword | yoursite.com
                      <span className="inline-block w-0.5 h-3.5 bg-zinc-400 rounded-full animate-pulse ml-0.5 align-middle" />
                    </span>
                    <div className="w-7 h-7 rounded-full bg-zinc-900 flex items-center justify-center shrink-0">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="white"><path d="M2 21l21-9L2 3v7l15 2-15 2z"/></svg>
                    </div>
                  </div>
                </div>
              </div>

              {/* Step 3 */}
              <div data-reveal className="flex gap-5">
                <div className="flex flex-col items-center">
                  <div className="w-px flex-1 bg-zinc-200 mb-2" />
                  <div className="w-9 h-9 rounded-full bg-zinc-900 flex items-center justify-center shrink-0">
                    <TrendingUp size={15} className="text-white" />
                  </div>
                  <div className="w-px flex-1 bg-zinc-200 mt-2" />
                </div>
                <div className="py-5 pt-6">
                  <p className="text-[16px] font-semibold text-zinc-900 mb-1.5">{steps[2].title}</p>
                  <p className="text-[14px] text-zinc-500 leading-relaxed">{steps[2].desc}</p>
                </div>
              </div>

              {/* Visual 3: horizontal ranking card */}
              <div data-reveal className="flex gap-5">
                <div className="flex flex-col items-center w-9 shrink-0">
                  <div className="w-px flex-1 bg-zinc-200" />
                </div>
                <div className="py-3 flex-1 min-w-0">
                  <div className="bg-white border border-zinc-200 rounded-2xl overflow-hidden shadow-sm">
                    <div className="px-4 py-2.5 border-b border-zinc-100 flex items-center gap-2">
                      <div className="w-1.5 h-1.5 rounded-full bg-emerald-400" />
                      <span className="text-[11px] font-semibold text-zinc-600">Search Console · Performance</span>
                      <span className="ml-auto text-[11px] text-zinc-400">Last 28 days</span>
                    </div>
                    <div className="flex divide-x divide-zinc-100">
                      {rankingRows.map((row) => (
                        <div key={row.keyword} className="flex-1 px-3 py-3 text-center">
                          <p className="text-[11px] text-zinc-400 truncate mb-1.5">{row.keyword}</p>
                          <div className="flex items-center justify-center gap-2 text-[12px]">
                            <span className="text-zinc-400">#{row.before}</span>
                            <span className="text-zinc-300">→</span>
                            <span className="font-bold text-emerald-600">#{row.after}</span>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>

            </div>

            {/* Right: SERP mockup */}
            <div data-reveal className="flex-1 flex flex-col justify-center">
              <div className="bg-white border border-zinc-200 rounded-2xl overflow-hidden shadow-sm">
                <div className="bg-zinc-100 px-4 py-2.5 flex items-center gap-2 border-b border-zinc-200">
                  <div className="flex gap-1.5">
                    <span className="w-2.5 h-2.5 rounded-full bg-red-400/60" />
                    <span className="w-2.5 h-2.5 rounded-full bg-yellow-400/60" />
                    <span className="w-2.5 h-2.5 rounded-full bg-green-400/60" />
                  </div>
                  <div className="flex-1 bg-white rounded-md px-3 py-1 flex items-center gap-2 border border-zinc-200 mx-3">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#a1a1aa" strokeWidth="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <span className="text-[11px] text-zinc-400">best coffee grinder</span>
                  </div>
                </div>
                <div className="px-5 py-4 space-y-4">
                  <p className="text-[10px] text-zinc-400 font-medium uppercase tracking-wider">About 4,200,000 results</p>

                  <div className="space-y-0.5 opacity-50">
                    <p className="text-[11px] text-zinc-400">bestreviews.com › coffee › grinders</p>
                    <p className="text-[13px] text-blue-600 font-medium">Best Coffee Grinders of 2024 — Expert Picks</p>
                    <p className="text-[11px] text-zinc-500">We tested 30+ grinders so you don't have to. Here are our top picks...</p>
                  </div>

                  <div className="space-y-0.5 opacity-50">
                    <p className="text-[11px] text-zinc-400">wirecutter.com › reviews › best-coffee-grinder</p>
                    <p className="text-[13px] text-blue-600 font-medium">The Best Coffee Grinder — Wirecutter</p>
                    <p className="text-[11px] text-zinc-500">After testing dozens of models, we recommend the Baratza Encore...</p>
                  </div>

                  <div className="space-y-0.5 bg-emerald-50 border border-emerald-200 rounded-xl px-3 py-2.5 relative">
                    <div className="absolute -top-2 right-3 bg-emerald-500 text-white text-[9px] font-bold px-2 py-0.5 rounded-full">↑ #3</div>
                    <p className="text-[11px] text-emerald-600">mycoffeeshop.com › best-coffee-grinder</p>
                    <p className="text-[13px] text-blue-600 font-medium">Best Coffee Grinders — My Coffee Shop</p>
                    <p className="text-[11px] text-zinc-500">Hand-picked grinders for every budget. Free shipping over $50...</p>
                  </div>

                  <div className="space-y-0.5 opacity-40">
                    <p className="text-[11px] text-zinc-400">amazon.com › best-sellers › coffee-grinders</p>
                    <p className="text-[13px] text-blue-600 font-medium">Amazon Best Sellers: Coffee Grinders</p>
                    <p className="text-[11px] text-zinc-500">Discover the best Coffee Grinders in Best Sellers...</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* Why Graphref */}
      <section ref={whyRef} className="py-32 md:py-40 px-6 bg-zinc-950">
        <div className="max-w-5xl mx-auto">
          <div data-reveal className="mb-[23px] flex justify-center">
            <Image
              src="/logo-mark-on-dark.svg"
              alt="Graphref"
              width={512}
              height={512}
              className="h-auto w-[56px] md:w-[64px]"
              priority={false}
            />
          </div>
          <h2 data-reveal className="text-[40px] md:text-[56px] font-bold tracking-tight mb-16 text-white leading-[1.1] text-center">
            Why Graphref, not something else?
          </h2>
          <div data-reveal className="overflow-x-auto">
            <table className="w-full min-w-[580px] text-[13px]">
              <thead>
                <tr className="border-b border-zinc-800">
                  <th className="text-left py-3 pr-6 text-[11px] font-semibold text-zinc-500 uppercase tracking-wider w-44"></th>
                  {[
                    "Results in GSC",
                    "Google-safe",
                    "Pay per use",
                    "Starts in < 60s",
                    "Refund if failed",
                  ].map((h) => (
                    <th key={h} className="text-center py-3 px-3 text-[11px] font-semibold text-zinc-500 uppercase tracking-wider leading-tight">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody className="divide-y divide-zinc-800/50">
                {[
                  { label: "SEO agency", note: "months of work", vals: [false, true, false, false, false], highlight: false },
                  { label: "Bot traffic tools", note: "fake HTTP requests", vals: [false, false, true, true, false], highlight: false },
                  { label: "Fiverr CTR gigs", note: "click farms, unverifiable", vals: [false, false, true, false, false], highlight: false },
                  { label: "Graphref", note: "", vals: [true, true, true, true, true], highlight: true },
                ].map((row) => (
                  <tr key={row.label} className={row.highlight ? "bg-zinc-900/70" : ""}>
                    <td className="py-4 pr-6">
                      <span className={`font-semibold ${row.highlight ? "text-white" : "text-zinc-400"}`}>{row.label}</span>
                      {row.note && <span className="block text-[11px] text-zinc-600 mt-0.5">{row.note}</span>}
                      {row.highlight && (
                        <span className="inline-flex mt-1 text-[10px] bg-emerald-500/15 text-emerald-400 border border-emerald-500/25 rounded-full px-2 py-0.5">you are here</span>
                      )}
                    </td>
                    {row.vals.map((v, i) => (
                      <td key={i} className="text-center py-4 px-3">
                        {v
                          ? <CheckCircle2 size={15} className="inline text-emerald-400" />
                          : <XCircle size={15} className="inline text-zinc-700" />
                        }
                      </td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <p data-reveal className="mt-8 text-[13px] text-zinc-600 leading-relaxed">
            &ldquo;Results in GSC&rdquo; — visits appear in Google Search Console Performance, confirming Google registered the organic click.
            &ldquo;Google-safe&rdquo; — click originates from a real SERP on a real device, not a spoofed request.
          </p>
        </div>
      </section>

      {/* Testimonials */}
      <section ref={testimonialsRef} className="py-32 md:py-40 px-6 bg-zinc-50">
        <div className="max-w-5xl mx-auto">
          <div data-reveal className="mb-[23px] flex justify-center">
            <Image
              src="/logo-mark.svg"
              alt="Graphref"
              width={512}
              height={512}
              className="h-auto w-[56px] md:w-[64px]"
              priority={false}
            />
          </div>
          <h2 data-reveal className="text-[40px] md:text-[56px] font-bold tracking-tight mb-16 leading-[1.1] text-center">
            {t("testimonials.title")}
          </h2>

          <div className="flex flex-col gap-4">
            <div data-reveal className="bg-white border border-zinc-200 rounded-2xl p-8 flex flex-col lg:flex-row gap-8 lg:items-center">
              <div className="flex-1 flex flex-col gap-5">
                <div className="flex items-center justify-between">
                  <div className="flex gap-1">
                    {[...Array(5)].map((_, i) => (
                      <svg key={i} width="20" height="20" viewBox="0 0 12 12" fill="#facc15">
                        <path d="M6 1l1.3 2.6 2.9.4-2.1 2 .5 2.9L6 7.5 3.4 8.9l.5-2.9L1.8 4l2.9-.4z" />
                      </svg>
                    ))}
                  </div>
                  <span className="text-[11px] text-zinc-400">{testimonials[0].date}</span>
                </div>
                <p className="text-[18px] text-zinc-700 leading-relaxed italic" style={{ fontFamily: "Georgia, 'Times New Roman', serif" }}>
                  &ldquo;{testimonials[0].text}&rdquo;
                </p>
                <div className="border-t border-zinc-100 pt-4 flex items-center gap-3 mt-auto">
                  <img src={testimonials[0].avatar} alt={testimonials[0].name} className="w-9 h-9 rounded-full object-cover shrink-0" />
                  <div>
                    <p className="text-[13px] font-semibold text-zinc-900">{testimonials[0].name}</p>
                    <p className="text-[12px] text-zinc-400">{testimonials[0].role}</p>
                  </div>
                </div>
              </div>
            </div>

            <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {testimonials.slice(1).map((t) => (
                <div data-reveal key={t.name} className="bg-white border border-zinc-200 rounded-2xl p-6 flex flex-col gap-4">
                  <div className="flex items-center justify-between">
                    <div className="flex gap-0.5">
                      {[...Array(5)].map((_, i) => (
                        <svg key={i} width="20" height="20" viewBox="0 0 12 12" fill="#facc15">
                          <path d="M6 1l1.3 2.6 2.9.4-2.1 2 .5 2.9L6 7.5 3.4 8.9l.5-2.9L1.8 4l2.9-.4z" />
                        </svg>
                      ))}
                    </div>
                    <span className="text-[11px] text-zinc-400">{t.date}</span>
                  </div>
                  <p className="text-[17px] text-zinc-600 leading-relaxed flex-1 italic" style={{ fontFamily: "Georgia, 'Times New Roman', serif" }}>
                    &ldquo;{t.text}&rdquo;
                  </p>
                  <div className="flex items-center gap-3 mt-auto pt-2 border-t border-zinc-100">
                    <img src={t.avatar} alt={t.name} className="w-8 h-8 rounded-full object-cover shrink-0" />
                    <div>
                      <p className="text-[13px] font-semibold text-zinc-900">{t.name}</p>
                      <p className="text-[12px] text-zinc-400">{t.role}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      {/* FAQ */}
      <section ref={faqRef} id="faq" className="scroll-mt-28 py-32 md:py-40 px-6 md:scroll-mt-32">
        <div className="max-w-5xl mx-auto">
          <div data-reveal className="mb-[23px] flex justify-center">
            <Image
              src="/logo-mark.svg"
              alt="Graphref"
              width={512}
              height={512}
              className="h-auto w-[56px] md:w-[64px]"
              priority={false}
            />
          </div>
          <h2 data-reveal className="text-[40px] md:text-[56px] font-bold tracking-tight mb-16 leading-[1.1] text-center">
            {t("faq.title")}
          </h2>
          <div className="mx-auto w-full max-w-4xl">
            {faqs.map((faq) => (
              <div data-reveal key={faq.q}>
                <FAQ q={faq.q} a={faq.a} />
              </div>
            ))}
          </div>
          <div data-reveal className="mx-auto mt-12 w-full max-w-4xl flex items-center gap-4 p-6 bg-zinc-50 rounded-2xl border border-zinc-100">
            <div className="flex-1">
              <p className="text-[15px] font-semibold text-zinc-900">{t("faq.stillHaveQuestions")}</p>
              <p className="text-[14px] text-zinc-500 mt-0.5">{t("faq.cantFind")}</p>
            </div>
            <a
              href="/contact"
              className="shrink-0 inline-flex items-center gap-2 bg-zinc-900 text-white text-[13px] font-medium px-5 py-3 rounded-xl hover:bg-zinc-700 transition-colors"
            >
              {t("faq.contactUs")}
            </a>
          </div>
        </div>
      </section>

      {/* Stats bar */}
      <section ref={statsRef} className="py-10 px-4 bg-zinc-900">
        <div className="max-w-5xl mx-auto grid grid-cols-3 gap-0">
          {stats.map((s, i) => {
            const Icon = s.icon;
            return (
              <div
                key={s.label}
                data-reveal
                className={`flex flex-col items-center gap-2 text-center py-5 px-2 ${
                  i < stats.length - 1 ? "border-r border-zinc-700" : ""
                }`}
              >
                <Icon size={15} className="text-zinc-500" />
                <span className="text-2xl md:text-[36px] font-bold tracking-tight text-white">{s.value}</span>
                <span className="text-[11px] md:text-[13px] text-zinc-400 leading-tight">{s.label}</span>
              </div>
            );
          })}
        </div>
      </section>

      {/* Pricing */}
      <section ref={pricingRef} id="pricing" className="scroll-mt-28 py-32 md:py-40 px-6 md:scroll-mt-32">
        <div className="max-w-5xl mx-auto">
          <h2 data-reveal className="text-[36px] md:text-[48px] font-bold tracking-tight mb-4 leading-[1.1]">
            {t("pricing.title")}
          </h2>
          <p data-reveal className="text-[17px] md:text-[19px] text-zinc-500 mb-14 max-w-2xl leading-relaxed">
            {t("pricing.sub")}
          </p>
          <div className="grid grid-cols-1 sm:grid-cols-3 gap-6">
            <PricingCards plans={plans} />
          </div>
          <div data-reveal className="mt-10 flex flex-wrap items-center gap-4 text-[13px] text-zinc-400">
            <span className="flex items-center gap-1.5">
              <CheckCircle size={13} />
              {t("pricing.badgeNoSub")}
            </span>
            <span className="flex items-center gap-1.5">
              <CheckCircle size={13} />
              {t("pricing.badgeNoExpire")}
            </span>
            <span className="flex items-center gap-1.5">
              <CheckCircle size={13} />
              {t("pricing.badgeFree")}
            </span>
            <span className="flex items-center gap-1.5 ml-auto opacity-60">
              <svg viewBox="0 0 10 14" width="8" height="11" fill="none" aria-hidden="true">
                <rect x="1" y="5" width="8" height="8" rx="1.5" stroke="#71717a" strokeWidth="1.3"/>
                <path d="M3 5V3.5a2 2 0 0 1 4 0V5" stroke="#71717a" strokeWidth="1.3" strokeLinecap="round"/>
              </svg>
              <svg viewBox="0 0 56 14" width="42" height="11" aria-label="PayPal" role="img">
                <text y="12" fontFamily="Arial, Helvetica, sans-serif" fontWeight="bold" fontSize="13">
                  <tspan fill="#253B80">Pay</tspan>
                  <tspan fill="#179BD7">Pal</tspan>
                </text>
              </svg>
            </span>
          </div>
        </div>
      </section>

      {/* Footer CTA */}
      <section ref={ctaRef} className="py-32 md:py-40 px-6 bg-zinc-50">
        <div className="max-w-5xl mx-auto">
          <h2 data-reveal className="text-[40px] md:text-[56px] font-bold tracking-tight mb-5 leading-[1.08]">
            {t("cta.title")}
          </h2>
          <p data-reveal className="text-[17px] md:text-[20px] text-zinc-500 mb-10 max-w-xl leading-relaxed">
            {t("cta.sub")}
          </p>
          <div data-reveal>
            <a
              href={TELEGRAM_URL}
              target="_blank"
              rel="noopener noreferrer"
              className="inline-flex items-center gap-2 bg-zinc-900 text-white text-[15px] font-medium px-6 py-4 rounded-xl hover:bg-zinc-700 transition-colors"
            >
              <MessageCircle size={17} />
              {t("cta.button")}
            </a>
          </div>
        </div>
      </section>

      {/* Footer */}
      <footer className="border-t border-zinc-100 py-10 px-6">
        <div className="max-w-5xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
          <span className="text-[13px] font-semibold tracking-tight">
            GRAPHREF
          </span>
          <div className="flex flex-wrap items-center gap-6 text-[12px] text-zinc-400">
            <a href="/contact" className="hover:text-zinc-600 transition-colors">
              {t("footer.contact")}
            </a>
            <a href="/terms" className="hover:text-zinc-600 transition-colors">
              {t("footer.terms")}
            </a>
            <a href="/privacy" className="hover:text-zinc-600 transition-colors">
              {t("footer.privacy")}
            </a>
            <span>© {new Date().getFullYear()} Graphref</span>
          </div>
        </div>
      </footer>
    </main>
  );
}
