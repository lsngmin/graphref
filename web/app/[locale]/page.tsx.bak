// Background chart — full-bleed behind hero content
const BG_RAW = [10, 14, 22, 40, 68, 98, 124, 138, 142, 140, 138, 136, 135, 134, 133];

function HeroBgChart() {
  const W = 1000;
  const H = 500;
  const padL = 70;
  const padR = 40;
  const padTop = 110;
  const padBot = 40;
  const maxVal = 150;

  const innerW = W - padL - padR;
  const innerH = H - padTop - padBot;

  const toX = (i: number) => padL + (i / (BG_RAW.length - 1)) * innerW;
  const toY = (v: number) => padTop + innerH - (v / maxVal) * innerH;

  const linePts = BG_RAW.map((v, i) => `${toX(i)},${toY(v)}`).join(" ");
  const fillPts = `${toX(0)},${padTop + innerH} ${linePts} ${toX(BG_RAW.length - 1)},${padTop + innerH}`;

  const yTicks = [0, 50, 100, 150];
  const xLabels = ["Mar 3", "Mar 17", "Mar 31", "Apr 14"];

  const endX = toX(BG_RAW.length - 1);
  const endY = toY(BG_RAW[BG_RAW.length - 1]);

  return (
    <svg
      viewBox={`0 0 ${W} ${H}`}
      preserveAspectRatio="xMidYMid slice"
      className="absolute inset-0 w-full h-full"
      aria-hidden="true"
    >
      <defs>
        <linearGradient id="bgChartFill" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stopColor="#d4d4d8" stopOpacity="0.45" />
          <stop offset="100%" stopColor="#d4d4d8" stopOpacity="0" />
        </linearGradient>
      </defs>

      {yTicks.map((tick) => (
        <g key={tick}>
          <line
            x1={padL} y1={toY(tick)}
            x2={W - padR} y2={toY(tick)}
            stroke="#e4e4e7" strokeWidth="1"
          />
          <text x={padL - 8} y={toY(tick) + 4} textAnchor="end" fontSize="11" fill="#a1a1aa">
            {tick}
          </text>
        </g>
      ))}

      {xLabels.map((label, i) => (
        <text
          key={label}
          x={toX(Math.round(i * (BG_RAW.length - 1) / (xLabels.length - 1)))}
          y={padTop + innerH + 20}
          textAnchor="middle" fontSize="11" fill="#a1a1aa"
        >
          {label}
        </text>
      ))}

      <polygon points={fillPts} fill="url(#bgChartFill)" />

      <polyline
        points={linePts}
        fill="none"
        stroke="#c4c4c8"
        strokeWidth="2.5"
        strokeLinecap="round"
        strokeLinejoin="round"
      />

      <circle cx={endX} cy={endY} r="8" fill="#a1a1aa" fillOpacity="0.15" />
      <circle cx={endX} cy={endY} r="4" fill="#71717a" />
    </svg>
  );
}

type ChatMessage = {
  id: number;
  from: "user" | "bot";
  text: string;
  time: string;
};

// typeStart: when the user begins typing in the input box
// delay: when the message is actually sent (appears in chat)
// ms/char is derived from (delay - typeStart) / text.length
const CHAT_SEQUENCE: { delay: number; typeStart?: number; msg: ChatMessage }[] = [
  { delay: 4200, typeStart: 800,  msg: { id: 1, from: "user", text: "/run best coffee grinder | mycoffeeshop.com", time: "9:41 AM" } },
  { delay: 6200,                  msg: { id: 2, from: "bot",  text: "✅ Job started — 10 visits queued", time: "9:41 AM" } },
  { delay: 8000,                  msg: { id: 3, from: "bot",  text: "📊 Done. Check Search Console in a few hours.", time: "9:42 AM" } },
  { delay: 11800, typeStart: 9400, msg: { id: 4, from: "user", text: "Wow, already seeing clicks 🚀", time: "9:43 AM" } },
  { delay: 13800,                 msg: { id: 5, from: "bot",  text: "Great! Run another keyword anytime.", time: "9:43 AM" } },
];

const LOOP_RESTART_DELAY = 17000;

function TypingDots() {
  return (
    <div className="flex items-center gap-1 px-3.5 py-2.5">
      {[0, 1, 2].map((i) => (
        <span
          key={i}
          className="w-1.5 h-1.5 rounded-full bg-zinc-400"
          style={{ animation: `chatDotBounce 1.2s ease-in-out ${i * 0.2}s infinite` }}
        />
      ))}
    </div>
  );
}

function TelegramMockChat() {
  const [messages, setMessages] = useState<ChatMessage[]>([]);
  const [typing, setTyping] = useState(false);
  const [inputText, setInputText] = useState("");
  const [fading, setFading] = useState(false);
  const msgAreaRef = useRef<HTMLDivElement>(null);

  const FADE_DURATION = 1200; // ms for fade-out before clearing

  useEffect(() => {
    let cancelled = false;
    let timers: ReturnType<typeof setTimeout>[] = [];

    function runSequence() {
      setFading(false);
      setMessages([]);
      setTyping(false);
      setInputText("");

      CHAT_SEQUENCE.forEach((item, idx) => {
        // Show bot typing indicator before each bot message
        if (item.msg.from === "bot") {
          const typingStart = item.delay - 1400;
          const t1 = setTimeout(() => {
            if (!cancelled) setTyping(true);
          }, typingStart);
          timers.push(t1);
        }

        // User message: animate typing char-by-char at human pace
        if (item.msg.from === "user" && item.typeStart !== undefined) {
          const start = item.typeStart;
          const duration = item.delay - start - 200;
          const chars = item.msg.text.length;
          for (let ci = 0; ci < chars; ci++) {
            const baseDelay = (duration / chars) * ci;
            const jitter = Math.random() * 30 - 15;
            const t2 = setTimeout(() => {
              if (!cancelled) setInputText(item.msg.text.slice(0, ci + 1));
            }, start + baseDelay + jitter);
            timers.push(t2);
          }
        }

        const t3 = setTimeout(() => {
          if (!cancelled) {
            setTyping(false);
            setInputText("");
            setMessages((prev) => [...prev, item.msg]);
          }
        }, item.delay);
        timers.push(t3);
      });

      // Fade out then restart
      const fadeStart = setTimeout(() => {
        if (!cancelled) setFading(true);
      }, LOOP_RESTART_DELAY - FADE_DURATION);
      timers.push(fadeStart);

      const loopTimer = setTimeout(() => {
        if (!cancelled) runSequence();
      }, LOOP_RESTART_DELAY);
      timers.push(loopTimer);
    }

    runSequence();
    return () => {
      cancelled = true;
      timers.forEach(clearTimeout);
    };
  }, []);

  // Scroll the clipped container so new messages push old ones up
  useEffect(() => {
    const el = msgAreaRef.current;
    if (!el) return;
    el.scrollTop = el.scrollHeight;
  }, [messages, typing]);

  return (
    <>
      <style>{`
        @keyframes chatDotBounce {
          0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
          30% { transform: translateY(-5px); opacity: 1; }
        }
        @keyframes chatMsgIn {
          from { opacity: 0; transform: translateY(8px); }
          to   { opacity: 1; transform: translateY(0); }
        }
        .chat-msg-enter { animation: chatMsgIn 0.28s ease-out forwards; }
      `}</style>
      <div className="w-[400px] bg-[#efeff4] rounded-2xl overflow-hidden shadow-xl border border-zinc-200/60 flex flex-col h-[480px]">
        {/* Header */}
        <div className="bg-white px-4 py-3 flex items-center gap-3 border-b border-zinc-100 shrink-0">
          <div className="relative shrink-0">
            <div className="w-10 h-10 rounded-full bg-zinc-900 flex items-center justify-center">
              <Image src="/logo-mark-on-dark.svg" alt="Graphref" width={24} height={24} />
            </div>
            <span className="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-400 rounded-full border-2 border-white" />
          </div>
          <div className="flex-1 min-w-0">
            <p className="text-[14px] font-semibold text-zinc-900 leading-none">Graphref Bot</p>
            <p className="text-[12px] text-green-500 mt-0.5">online</p>
          </div>
          <div className="flex items-center gap-3 text-zinc-300">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
          </div>
        </div>

        {/* Messages — flex-1 fills remaining card space, overflow hidden so messages scroll up */}
        <div
          ref={msgAreaRef}
          className="flex-1 overflow-hidden px-4 py-4 text-[13px]"
          style={{
            scrollBehavior: "smooth",
            opacity: fading ? 0 : 1,
            transition: fading ? `opacity ${FADE_DURATION}ms ease-out` : "none",
          }}
        >
          <div className="space-y-3">
            <div className="flex items-center gap-3 my-2">
              <div className="flex-1 h-px bg-zinc-200/70" />
              <span className="text-[10px] text-zinc-400 font-medium">Today</span>
              <div className="flex-1 h-px bg-zinc-200/70" />
            </div>

            {messages.map((msg) =>
              msg.from === "user" ? (
                <div key={msg.id} className="flex justify-end chat-msg-enter">
                  <div className="flex flex-col items-end gap-1 max-w-[82%]">
                    <div className="bg-[#4f81e0] text-white rounded-2xl rounded-tr-sm px-3.5 py-2.5 leading-snug">
                      {msg.text}
                    </div>
                    <span className="text-[10px] text-zinc-400 pr-1">{msg.time} ✓✓</span>
                  </div>
                </div>
              ) : (
                <div key={msg.id} className="flex justify-start gap-2 chat-msg-enter">
                  <div className="w-7 h-7 rounded-full bg-zinc-900 flex items-center justify-center shrink-0 mt-auto mb-4">
                    <Image src="/logo-mark-on-dark.svg" alt="Graphref" width={16} height={16} />
                  </div>
                  <div className="flex flex-col gap-1 max-w-[82%]">
                    <div className="bg-white text-zinc-800 rounded-2xl rounded-tl-sm px-3.5 py-2.5 leading-snug shadow-sm">
                      {msg.text}
                    </div>
                    <span className="text-[10px] text-zinc-400 pl-1">{msg.time}</span>
                  </div>
                </div>
              )
            )}

            {typing && (
              <div className="flex justify-start gap-2 chat-msg-enter">
                <div className="w-7 h-7 rounded-full bg-zinc-900 flex items-center justify-center shrink-0">
                  <Image src="/logo-mark-on-dark.svg" alt="Graphref" width={16} height={16} />
                </div>
                <div className="bg-white rounded-2xl rounded-tl-sm shadow-sm">
                  <TypingDots />
                </div>
              </div>
            )}
          </div>
        </div>

        {/* Input */}
        <div className="bg-white px-3 py-2.5 flex items-center gap-2 border-t border-zinc-100 shrink-0">
          <div className="flex-1 bg-zinc-100 rounded-full px-4 py-2 text-[13px] text-zinc-700 min-h-[36px] flex items-center">
            {inputText || <span className="text-zinc-400">Message</span>}
            {inputText && (
              <span className="inline-block w-0.5 h-3.5 bg-zinc-500 rounded-full animate-pulse ml-0.5" />
            )}
          </div>
          <div className="w-8 h-8 rounded-full bg-zinc-900 flex items-center justify-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M2 21l21-9L2 3v7l15 2-15 2z"/></svg>
          </div>
        </div>
      </div>
    </>
  );
}

